{
  "name": "gephi-mcp-plugin-sidecar",
  "version": "0.1.12",
  "private": true,
  "type": "module",
  "description": "MCP sidecar for the Gephi MCP Plugin localhost control endpoint.",
  "bin": {
    "gephi-mcp-sidecar": "mcp-server/index.js",
    "gephi-mcp": "scripts/mcp-call.js"
  },
  "scripts": {
    "mcp": "node mcp-server/index.js",
    "mcp:list": "node scripts/mcp-call.js list",
    "mcp:health": "node scripts/mcp-call.js gephi_health",
    "mcp:summary": "node scripts/mcp-call.js get_graph_summary",
    "mcp:open-example": "node scripts/mcp-call.js open_graph \"{\\\"path\\\":\\\"$PWD/examples/tiny.graphml\\\"}\"",
    "mcp:save-project": "node scripts/mcp-call.js save_project",
    "mcp:export-preview": "node scripts/mcp-call.js export_preview '{\"path\":\"/tmp/gephi-preview.png\",\"width\":2400,\"height\":1800,\"edgeThickness\":0.25,\"arrowSize\":0}'",
    "mcp:profile": "node scripts/mcp-call.js graph_profile",
    "mcp:top-degree": "node scripts/mcp-call.js top_nodes '{\"score\":\"degree\",\"limit\":20}'",
    "mcp:top-weighted": "node scripts/mcp-call.js top_nodes '{\"score\":\"weightedDegree\",\"limit\":20}'",
    "mcp:layouts": "node scripts/mcp-call.js list_layouts",
    "mcp:statistics": "node scripts/mcp-call.js list_statistics",
    "mcp:nodes": "node scripts/mcp-call.js sample_nodes '{\"limit\":10}'",
    "mcp:analyze-neighborhood": "node scripts/mcp-call.js analyze_neighborhood '{\"id\":\"REPLACE_WITH_NODE_ID\",\"depth\":1,\"limit\":200}'",
    "mcp:focus-neighborhood": "node scripts/mcp-call.js focus_neighborhood '{\"id\":\"REPLACE_WITH_NODE_ID\",\"depth\":1,\"limit\":200}'",
    "mcp:preset": "node scripts/mcp-call.js apply_graph_preset",
    "mcp:partition-kind": "node scripts/mcp-call.js partition_nodes '{\"attribute\":\"kind\"}'",
    "mcp:ranking-degree": "node scripts/mcp-call.js ranking_nodes '{\"attribute\":\"degree\",\"minSize\":6,\"maxSize\":32}'",
    "mcp:style-preset": "node scripts/mcp-call.js apply_style_preset '{\"minSize\":4,\"maxSize\":24}'",
    "mcp:view-presets": "node scripts/mcp-call.js list_view_presets",
    "mcp:view-preset-dry": "node scripts/mcp-call.js apply_view_preset '{\"preset\":\"architecture_overview\",\"dryRun\":true}'",
    "mcp:view-preset": "node scripts/mcp-call.js apply_view_preset '{\"preset\":\"architecture_overview\"}'",
    "mcp:style-node-kind-type": "node scripts/mcp-call.js style_nodes '{\"attribute\":\"kind\",\"value\":\"type\",\"color\":\"#1b8f2a\",\"size\":18,\"alpha\":0.95}'",
    "mcp:thin-edges": "node scripts/mcp-call.js style_edges '{\"attribute\":\"kind\",\"op\":\"exists\",\"weight\":0.25,\"alpha\":0.45,\"limit\":10000}'",
    "mcp:circle-node-kind-package": "node scripts/mcp-call.js layout_nodes_circle '{\"attribute\":\"kind\",\"value\":\"package\",\"radius\":1200,\"fixed\":true}'",
    "mcp:filter-kind": "node scripts/mcp-call.js filter_graph '{\"element\":\"node\",\"attribute\":\"kind\",\"op\":\"exists\",\"mode\":\"view\"}'",
    "mcp:reset-filters": "node scripts/mcp-call.js reset_filters",
    "mcp:run-layout": "node scripts/mcp-call.js run_layout '{\"name\":\"ForceAtlas 2\",\"iterations\":100,\"parameters\":{\"scalingRatio\":15,\"gravity\":1,\"adjustSizes\":true,\"barnesHutOptimization\":true}}'",
    "mcp:run-degree": "node scripts/mcp-call.js run_statistics '{\"name\":\"Degree\"}'",
    "mcp:run-modularity": "node scripts/mcp-call.js run_statistics '{\"name\":\"Modularity\",\"parameters\":{\"useWeight\":false,\"resolution\":1.0}}'",
    "gephi:reload": "scripts/reload-gephi-plugin.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  }
}
